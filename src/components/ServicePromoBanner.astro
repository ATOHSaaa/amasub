---
import type { ServiceId } from '@/config/site';

interface Props {
  id: ServiceId;
}

const { id } = Astro.props;
const font =
  "'M PLUS Rounded 1c', 'Hiragino Maru Gothic ProN', 'Hiragino Sans', sans-serif";
---

{
  id === 'kindle-unlimited' ? (
    <svg
      class="sidebar-promo__art"
      viewBox="0 0 280 132"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      focusable="false"
    >
      <rect width="280" height="132" rx="14" fill="#E8F3FF" />
      <rect
        x="1.5"
        y="1.5"
        width="277"
        height="129"
        rx="12.5"
        fill="none"
        stroke="#4A9EFF"
        stroke-width="2"
        opacity="0.3"
      />
      <circle cx="248" cy="24" r="28" fill="#4A9EFF" opacity="0.12" />
      <circle cx="236" cy="108" r="18" fill="#FFE066" opacity="0.35" />
      <g transform="translate(14 22)">
        <rect width="56" height="68" rx="12" fill="#4A9EFF" opacity="0.15" />
        <g transform="translate(28 34)">
          <rect x="-20" y="-24" width="40" height="48" rx="5" fill="#4A9EFF" />
          <rect x="-20" y="-24" width="9" height="48" rx="5" fill="#2D7AD4" />
          <rect x="-6" y="-12" width="22" height="3" rx="1.5" fill="#fff" opacity="0.85" />
          <rect x="-6" y="-4" width="18" height="3" rx="1.5" fill="#fff" opacity="0.65" />
          <rect x="-6" y="4" width="20" height="3" rx="1.5" fill="#fff" opacity="0.65" />
          <rect x="-6" y="12" width="14" height="3" rx="1.5" fill="#fff" opacity="0.65" />
        </g>
      </g>
      <rect x="76" y="20" width="52" height="20" rx="10" fill="#4A9EFF" opacity="0.15" />
      <text
        x="102"
        y="30"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="#1A6FD4"
        font-family={font}
        font-size="10"
        font-weight="800">読む</text>
      <text
        x="76"
        y="58"
        fill="#1A6FD4"
        font-family={font}
        font-size="16"
        font-weight="800">Kindle Unlimited</text>
      <text
        x="76"
        y="78"
        fill="#5C5670"
        font-family={font}
        font-size="11"
        font-weight="700">月額980円で電子書籍が読み放題</text>
      <rect x="76" y="90" width="188" height="30" rx="15" fill="#4A9EFF" />
      <text
        x="170"
        y="105"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="#fff"
        font-family={font}
        font-size="12"
        font-weight="800">公式ページを見る →</text>
    </svg>
  ) : (
    <svg
      class="sidebar-promo__art"
      viewBox="0 0 280 132"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      focusable="false"
    >
      <rect width="280" height="132" rx="14" fill="#FFF3E6" />
      <rect
        x="1.5"
        y="1.5"
        width="277"
        height="129"
        rx="12.5"
        fill="none"
        stroke="#FF9F43"
        stroke-width="2"
        opacity="0.35"
      />
      <circle cx="250" cy="26" r="30" fill="#FF9F43" opacity="0.15" />
      <circle cx="28" cy="108" r="16" fill="#FF6B5B" opacity="0.2" />
      <g transform="translate(14 18)">
        <rect width="56" height="68" rx="12" fill="#FF9F43" opacity="0.18" />
        <g transform="translate(28 30)">
          <path
            d="M-20 10 Q-20 -12 0 -18 Q20 -12 20 10"
            stroke="#FF9F43"
            stroke-width="4.5"
            fill="none"
            stroke-linecap="round"></path>
          <rect x="-26" y="6" width="12" height="26" rx="6" fill="#FF9F43" />
          <rect x="14" y="6" width="12" height="26" rx="6" fill="#FF9F43" />
        </g>
      </g>
      <rect x="76" y="20" width="52" height="20" rx="10" fill="#FF9F43" opacity="0.2" />
      <text
        x="102"
        y="30"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="#C96A00"
        font-family={font}
        font-size="10"
        font-weight="800">聴く</text>
      <text
        x="76"
        y="58"
        fill="#C96A00"
        font-family={font}
        font-size="20"
        font-weight="800">Audible</text>
      <text
        x="76"
        y="78"
        fill="#5C5670"
        font-family={font}
        font-size="11"
        font-weight="700">月額1,500円でオーディオブック</text>
      <rect x="76" y="90" width="188" height="30" rx="15" fill="#FF9F43" />
      <text
        x="170"
        y="105"
        text-anchor="middle"
        dominant-baseline="middle"
        fill="#fff"
        font-family={font}
        font-size="12"
        font-weight="800">公式ページを見る →</text>
    </svg>
  )
}
