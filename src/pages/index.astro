---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import SiteSearch from '@/components/SiteSearch.astro';
import { getPublishedPosts } from '@/lib/posts';
import { site } from '@/config/site';

const posts = await getPublishedPosts();
const latest = posts.slice(0, 12);
---

<BaseLayout
  title={site.name}
  description={site.description}
  pathname="/"
  structuredData="WebSite"
>
  <section class="home-search" aria-label="記事検索">
    <SiteSearch instance="home" variant="hero" />
  </section>

  <section aria-labelledby="latest-posts">
    <h1 id="latest-posts" class="page-title">新着記事</h1>
    {latest.length === 0 ? (
      <p>記事を準備中です。</p>
    ) : (
      <div class="post-list">
        {latest.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    )}
    {posts.length > 12 && (
      <div class="post-list-footer">
        <a class="text-link-arrow" href="/posts/">すべての記事を見る →</a>
      </div>
    )}
  </section>
</BaseLayout>
